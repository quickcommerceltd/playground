		"@zapp/utils": "workspace:*",
		"better-sqlite3": "12.9.0",
		"kysely": "^0.28.16",
		"reflect-metadata": "0.2.2",
		"rxjs": "7.8.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@nestjs/cli": "11.0.19",
		"@nestjs/testing": "11.1.18",
		"@types/better-sqlite3": "7.6.13",
		"@zapp/typescript-config": "workspace:*",
		"tsx": "4.21.0",
