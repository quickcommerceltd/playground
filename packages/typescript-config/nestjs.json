{
	"extends": "./base.json",
	"compilerOptions": {
		"lib": ["ES2022"],
		"module": "CommonJS",
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"rewriteRelativeImportExtensions": true,
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"noEmit": true,
		"declaration": false,
		"declarationMap": false
	}
}
